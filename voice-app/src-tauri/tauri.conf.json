{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yawp",
  "version": "0.1.0",
  "identifier": "com.local.voice",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Yawp",
        "width": 1180,
        "height": 820,
        "minWidth": 760,
        "minHeight": 560,
        "center": true,
        "decorations": true,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "backgroundColor": "#F7F3EA"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
