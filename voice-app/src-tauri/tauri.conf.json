{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yawp",
  "mainBinaryName": "yawp",
  "version": "0.2.3",
  "identifier": "com.local.voice",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Yawp",
        "width": 1180,
        "height": 820,
        "minWidth": 760,
        "minHeight": 560,
        "center": true,
        "decorations": true,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "visible": false,
        "backgroundColor": "#fbfbfa"
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: blob: data:; img-src 'self' data: blob: http://127.0.0.1:17893; media-src 'self' blob: http://127.0.0.1:17893; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:17893 ws://127.0.0.1:17893 https://api.github.com; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
