#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

"$ROOT/scripts/check"

printf '\n==> Tauri package build\n'
(
  cd "$ROOT/voice-app"
  npm run tauri build -- --bundles deb
)

printf '\n==> AppImage package build\n'
"$ROOT/scripts/package-appimage"

printf '\nRelease checks passed.\n'
