#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON_BIN="${YAWP_PYTHON:-$ROOT/sidecar/.venv/bin/python}"

step() {
  printf '\n==> %s\n' "$1"
}

if [[ ! -x "$PYTHON_BIN" ]]; then
  printf 'Missing Python environment: %s\n' "$PYTHON_BIN" >&2
  printf 'Run ./install.sh or create sidecar/.venv and install sidecar requirements.\n' >&2
  exit 2
fi

if ! command -v npm >/dev/null 2>&1; then
  printf 'Missing npm. Install Node 20+ before running checks.\n' >&2
  exit 2
fi

if ! command -v cargo >/dev/null 2>&1; then
  printf 'Missing cargo. Install Rust before running checks.\n' >&2
  exit 2
fi

step "Python backend tests"
"$PYTHON_BIN" -m pytest

step "Python lint"
"$PYTHON_BIN" -m ruff check "$ROOT/sidecar" "$ROOT/tools"

step "Frontend unit tests"
(
  cd "$ROOT/voice-app"
  npm test
)

step "Frontend lint"
(
  cd "$ROOT/voice-app"
  npm run lint
)

step "Frontend Playwright smoke tests"
(
  cd "$ROOT/voice-app"
  npx playwright install chromium >/dev/null
  npm run test:e2e
)

step "Frontend production build"
(
  cd "$ROOT/voice-app"
  npm run build
)

step "Installer static smoke test"
"$ROOT/scripts/install-smoke"

step "Tauri Rust compile check"
(
  cd "$ROOT/voice-app/src-tauri"
  cargo fmt --check
  cargo clippy --all-targets -- -D warnings
  cargo check
)

printf '\nAll checks passed.\n'
