#!/usr/bin/env bash
set -euo pipefail

BASE="${YAWP_SIDECAR_URL:-http://127.0.0.1:17893}"

python3 - "$BASE" <<'PY'
import json
import sys
import urllib.error
import urllib.request

base = sys.argv[1].rstrip("/")
try:
    with urllib.request.urlopen(f"{base}/diagnostics", timeout=3) as response:
        data = json.load(response)
except urllib.error.URLError as e:
    print(f"Yawp sidecar is not reachable at {base}: {e}", file=sys.stderr)
    sys.exit(1)

print(json.dumps(data, indent=2, sort_keys=True))
PY
